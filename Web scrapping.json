      "id": "872ca891-590d-41f7-a739-5141f615726c",
      "name": "Code in JavaScript",
      "disabled": true
    },
    {
      "parameters": {
        "jsCode": "// Get the input data\nconst items = $input.all();\n\n// Extract the data array from the first item\nconst data = items[0].json.data;\n\n// Convert each lead to formatted text\nlet textOutput = \"NEW LEADS:\\n\\n\";\n\ndata.forEach((lead, index) => {\n  textOutput += `Lead #${index + 1}\\n`;\n  textOutput += `Name: ${lead[\"Full Name\"]}\\n`;\n  textOutput += `Email: ${lead.Email}\\n`;\n  textOutput += `Service: ${lead.Service}\\n`;\n  textOutput += `Budget: $${lead.Budget}\\n`;\n  textOutput += `\\n---\\n\\n`;\n});\n\n// Return the text output\nreturn [\n  {\n    json: {\n      text: textOutput\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
