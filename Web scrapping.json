    {
      "parameters": {
        "jsCode": "// Get the input data\nconst items = $input.all();\n\n// Extract the data array from the first item\nconst data = items[0].json.data;\n\n// Sort the data by Budget from highest to lowest\nconst sortedData = data.sort((a, b) => b.Budget - a.Budget);\n\n// Return the sorted data in the same structure\nreturn [\n  {\n    json: {\n      data: sortedData\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
