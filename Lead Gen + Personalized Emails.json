    {
      "parameters": {
        "jsCode": "const newData = $('Scrape Maps').all();\nconst existing = $('Get Saved Leads').all();\n\n// Normalize helpers\nconst normalizePhone = (phone) => {\n  if (!phone) return '';\n  return phone.replace(/\\D/g, '');\n};\n\nconst normalizeWebsite = (url) => {\n  if (!url) return '';\n  return url\n    .toLowerCase()\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .replace(/\\/$/, '')\n    .trim();\n};\n\n// Existing sets\nconst existingPhones = new Set(\n  existing.map(e => normalizePhone(e.json.Phone)).filter(Boolean)\n);\n\nconst existingWebsites = new Set(\n  existing.map(e => normalizeWebsite(e.json.Website)).filter(Boolean)\n);\n\n// Filter logic\nconst filtered = newData.filter(item => {\n  const phone = normalizePhone(item.json.phoneUnformatted || item.json.phone);\n  const website = normalizeWebsite(item.json.website);\n\n  // ❌ Skip if BOTH identifiers missing\n  if (!phone && !website) return false;\n\n  // ❌ Skip if duplicate by either\n  if (\n    (phone && existingPhones.has(phone)) ||\n    (website && existingWebsites.has(website))\n  ) {\n    return false;\n  }\n\n  // Prevent duplicates within same batch\n  if (phone) existingPhones.add(phone);\n  if (website) existingWebsites.add(website);\n\n  return true;\n});\n\nreturn filtered;"
      },
