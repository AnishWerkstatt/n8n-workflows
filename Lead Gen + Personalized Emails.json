      "parameters": {
        "jsCode": "// Generate a random delay between 1 and 5 \n// seconds (including decimals)\nconst min = 1;  // minimum seconds\nconst max = 5;  // maximum seconds\n\n// Create random decimal delay, e.g. 1.7 or\n// 4.3 seconds\nconst delaySeconds = (Math.random() * (max - \nmin) + min).toFixed(1);\n\n// Pass to the next node\nreturn [{ delaySeconds }];"
      },
